# ─── CAPRO · TorqAI Technologies Inc. ──────────────────────────────────────
# Copy to `.env` and fill in. Never commit the real .env.

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/capro?schema=public"

# Public base URL of this deployment (used for Twilio + Stripe callbacks)
APP_BASE_URL="https://app.torqai.ca"

# ─── Better Auth ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="https://app.torqai.ca"

# OAuth social providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Empty in dev → verification/reset codes print to the server console.
RESEND_API_KEY=""
EMAIL_FROM="CAPRO <no-reply@torqai.ca>"

# ─── Google Gemini (Google Gen AI SDK) ─────────────────────────────────────
# Gemini powers ALL intelligence + voice: TTS, live conversation, transcription,
# summaries, extraction. Twilio is transport only (numbers, SMS, media).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_LIVE_MODEL="gemini-2.5-flash-native-audio-latest"

# ─── Voice bridge (Twilio Media Streams ↔ Gemini Live) ─────────────────────
# Run separately:  node scripts/voice-bridge.mjs
VOICE_BRIDGE_PORT="3211"
VOICE_BRIDGE_SECRET=""  # random secret guarding the internal /api/voice/* routes
# Public wss URL Twilio Media Streams connects to (e.g. wss://<tunnel>/media).
# Empty → telephony falls back to the turn-based Gather + Gemini-TTS flow.
PUBLIC_WSS_URL=""

# ─── Twilio (Programmable Voice + SMS) — transport only ────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# E.164 number used to send outbound trigger SMS, e.g. +15145550123
TWILIO_SMS_FROM=""

# ─── Stripe (Subscriptions + metered overage) ──────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs for each tier — auto-filled by: node scripts/stripe-setup.mjs
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PREMIUM=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_SCALE=""

# ConversationRelay (lowest-latency voice path): Twilio does STT/TTS at its
# edge and the bridge exchanges text with Gemini. Requires enabling the
# "Predictive and Generative AI/ML Features Addendum" in the Twilio Console.
USE_CONVERSATION_RELAY="false"
# Optional TTS overrides, e.g. provider "ElevenLabs" or "Google" + a voice id.
CONVERSATION_RELAY_TTS_PROVIDER=""
CONVERSATION_RELAY_VOICE=""
# Optional STT tuning for ConversationRelay (faster end-of-utterance detection):
CONVERSATION_RELAY_TRANSCRIPTION_PROVIDER=""
CONVERSATION_RELAY_SPEECH_MODEL=""
